// Test configuration for CI/smoke testing
// Uses stub mode to avoid requiring real databases

params {
    // Profile metadata
    config_profile_name = "aDNA Tel-Megiddo Test"
    config_profile_description = "Test profile for CI/smoke testing without real databases"

    // Use stub mode for database-dependent processes
    stub_mode = true

    // Small test input (CI will provide a tiny FASTQ file)
    input_dir = "tests/data/*.fq.gz"
    outdir = "/tmp/test_results"
    script = "src/nf_helper"
    
    // These paths can be dummy values since stub mode skips the real execution
    kraken2_db = "/tmp/dummy_kraken_db"
    bracken_db = "/tmp/dummy_bracken_db"
    read_len = 50
}

// Process resource configuration for fast testing
process {
    executor = 'local'
    cpus = 1
    memory = 512.MB
    time = 5.m
}


