// Custom Nextflow configuration for tel-megiddo aDNA on LUNARC

// Pipeline Parameters
params {
    
    // Profile metadata
    config_profile_name = "aDNA Tel-Megiddo"
    config_profile_description = "This config file is for running the pipline on LUNARC HPC servers"

    // Input and output directories
    input_dir = "data/telmgd_qced/*.fq.gz"
    outdir = "results"
    script = "src/nf_helper"
    kraken2_db = "/home/chandru/lu2025-12-38/Students/chandru/kraken_databases/run_gallus_standard"
    bracken_db = "/home/chandru/lu2025-12-38/Students/chandru/kraken_databases/run_gallus_standard"
    read_len = 50 // Ancient DNA average size
}

// Process resource configuration
profiles {
  slurm {
    // Default process settings for the SLURM profile
    process {
      executor = 'slurm'
      // map partition: explicit clusterOptions gives full control
      clusterOptions = '--partition=lu48'
      cpus = 1
      memory = 4.GB
      time = 1.h
    }

    // Per-process overrides by process name (use the exact tag/name used in your nf files)
    process {
      withName: 'KRAKEN' {
        cpus = 8
        memory = 32.GB
        time = 30.m
        clusterOptions = '--partition=lu48'
      }
      withName: 'BRACKEN' {
        cpus = 4
        memory = 16.GB
        time = 20.m
        clusterOptions = '--partition=lu48'
      }
      withName: 'SEQ_LEN' {
        cpus = 1
        memory = 2.GB
        time = 30.m
      }
    }
  }
}